version: '3.8'

networks:
  {{.Project}}-network:
    driver: bridge

services:
{{- if .Domain}}
  caddy:
    image: caddy:2-alpine
    container_name: {{.Project}}-caddy
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    networks:
      - {{.Project}}-network
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
{{- end}}

{{- range .Services}}
  {{$.Project}}-{{.}}:
    image: {{$.Registry}}/{{$.Project}}_{{.}}:${{"{"}}{{. | upper}}_VERSION:-latest{{"}"}}
    container_name: {{$.Project}}-{{.}}
    restart: unless-stopped
    env_file:
      - ./{{if $.IsMonorepo}}{{.}}/{{end}}.env
    networks:
      - {{$.Project}}-network
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    # Expose ports to host (uncomment for local testing or production without reverse proxy)
    # ports:
    #   - "8000:8000"  # Format: "host:container"
    # Or expose to other containers only (no host access):
    # expose:
    #   - "8000"
    # Add your service-specific configuration here (volumes, healthchecks, etc.)
{{end}}

{{- if .Domain}}
volumes:
  caddy_data:
  caddy_config:
{{- end}}
